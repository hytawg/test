{
  "name": "screenstudio-clone",
  "version": "1.0.0",
  "description": "Mac-optimized screen recording and editing desktop app",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:mac": "electron-builder --mac",
    "lint": "eslint src electron --ext .ts,.tsx",
    "check": "tsc --noEmit && echo '✓ TypeScript OK'"
  },
  "keywords": [
    "screen-recorder",
    "mac",
    "electron"
  ],
  "author": "ScreenStudio Clone",
  "license": "MIT",
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^9.6.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.5",
    "typescript": "^5.5.2",
    "vite": "^5.3.1"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "clsx": "^2.1.1",
    "electron-store": "^9.0.0",
    "framer-motion": "^11.3.2",
    "lucide-react": "^0.395.0",
    "mp4-muxer": "^5.2.2",
    "react": "^18.3.1",
    "react-color": "^2.19.3",
    "react-dom": "^18.3.1",
    "react-rnd": "^10.4.13"
  },
  "build": {
    "appId": "com.screenstudio.clone",
    "productName": "ScreenStudio",
    "mac": {
      "category": "public.app-category.video",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "hardenedRuntime": true
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ]
  }
}

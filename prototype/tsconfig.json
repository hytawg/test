{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "../src/main/focusEngine": ["../src/main/focusEngine"]
    }
  },
  "include": ["./**/*.ts", "../src/main/focusEngine.ts"],
  "exclude": ["dist", "node_modules"]
}

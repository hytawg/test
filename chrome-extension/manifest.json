{
  "manifest_version": 3,
  "name": "ScreenStudio Recorder",
  "version": "1.0.0",
  "description": "Control ScreenStudio recording from your browser",
  "action": {
    "default_popup": "popup.html",
    "default_title": "ScreenStudio Recorder"
  },
  "permissions": [],
  "host_permissions": [
    "http://127.0.0.1:7823/*"
  ]
}
